<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" id="WebApp_ID" version="4.0">
  <display-name>tps</display-name>
  <servlet>
	<servlet-name>creerclient</servlet-name>
	<servlet-class>servlets.CreerClient</servlet-class>	
  </servlet>
  <servlet-mapping>
	<servlet-name>creerclient</servlet-name>
	<url-pattern>/CreerClient</url-pattern>
  </servlet-mapping>
  
  <servlet>
	<servlet-name>creerreservation</servlet-name>
	<servlet-class>servlets.CreerReservation</servlet-class>	
  </servlet>
  <servlet-mapping>
	<servlet-name>creerreservation</servlet-name>
	<url-pattern>/CreerReservation</url-pattern>
  </servlet-mapping>
  
  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
    <welcome-file>index.jsp</welcome-file>
    <welcome-file>index.htm</welcome-file>
  </welcome-file-list>
</web-app>